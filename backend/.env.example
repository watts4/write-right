OAUTH_REDIRECT_URI=https://your-cloud-run-url/oauth/callback
FRONTEND_URL=https://write-right-app.web.app

# For seeding mock data (seed.ts only)
NOTION_TOKEN=secret_your_integration_secret_here
NOTION_DATABASE_ID=your_32char_database_id_here
